· Minimize VM exits

5. Implementation:

```c
static void sev_handle_batch(VirtIODevice *vdev, VirtQueue *vq)
{
    VirtQueueElement *elems[64];
    int num = 0;
    
    // 1. Pop up to 64 descriptors
    while (num < 64 && (elems[num] = virtqueue_pop(vq, ...))) {
        num++;
    }
    
    // 2. Batch decrypt using hardware
    sev_batch_decrypt(elems, num);
    
    // 3. Process all descriptors
    for (int i = 0; i < num; i++) {
        process_descriptor(elems[i]);
    }
    
    // 4. Batch encrypt results
    sev_batch_encrypt(elems, num);
    
    // 5. Push all to used ring
    for (int i = 0; i < num; i++) {
        virtqueue_push(vq, elems[i], len);
    }
    
    // 6. Single interrupt for all
    virtio_notify(vdev, vq);
}
