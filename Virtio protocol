Handling In-Flight I/O During Migration

The Challenge: Descriptors in flight when migration starts.

```c
// QEMU migration code
static int virtio_block_pre_save(void *opaque)
{
    VirtIOBlock *s = opaque;
    
    // 1. Drain all pending I/O
    for (int i = 0; i < s->num_queues; i++) {
        VirtQueue *vq = virtio_get_queue(vdev, i);
        
        // Wait for all descriptors to complete
        while (!virtqueue_empty(vq)) {
            // Poll for completions
            virtio_queue_notify(vdev, vq);
            // Small timeout to avoid busy-wait
            g_usleep(100);
        }
    }
    
    // 2. Save current state
    s->vq_state[i] = vq->last_avail_idx;
    
    return 0;
}

static int virtio_block_post_load(void *opaque, int version_id)
{
    VirtIOBlock *s = opaque;
    
    // 3. Restore state on destination
    for (int i = 0; i < s->num_queues; i++) {
        VirtQueue *vq = virtio_get_queue(vdev, i);
        vq->last_avail_idx = s->vq_state[i];
    }
    
    return 0;
}
```

Zero-Downtime Migration

VIRTIO_F_RING_RESET (virtio 1.2+):

```c
// Guest driver can reset virtqueue without resetting device
static void virtqueue_reset(VirtQueue *vq)
{
    // 1. Disable queue
    vq->vring.avail->flags |= VRING_AVAIL_F_NO_INTERRUPT;
    
    // 2. Drain all pending descriptors
    virtio_queue_clear(vq);
    
    // 3. Reset indices
    vq->last_avail_idx = 0;
    vq->avail_idx = 0;
    vq->used_idx = 0;
    
    // 4. Re-enable
    vq->vring.avail->flags &= ~VRING_AVAIL_F_NO_INTERRUPT;
}
```

