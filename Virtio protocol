Cache Management: ARM requires explicit cache maintenance.

```c
// After writing to buffer that device will read
static void arm_cache_flush(void *addr, size_t len)
{
    // Clean data cache (write to physical memory)
    __asm__ volatile (
        "dc cvac, %0" : : "r"(addr) : "memory"
    );
    // Data synchronization barrier
    __asm__ volatile ("dsb ish" ::: "memory");
}

// Before reading buffer that device wrote
static void arm_cache_invalidate(void *addr, size_t len)
{
    // Invalidate data cache (read from physical memory)
    __asm__ volatile (
        "dc ivac, %0" : : "r"(addr) : "memory"
    );
    __asm__ volatile ("dsb ish" ::: "memory");
}
```

