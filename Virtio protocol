static int vhost_net_open(struct inode *inode, struct file *f)
{
    struct vhost_net *n = kmalloc(sizeof(*n), GFP_KERNEL);
    struct vhost_virtqueue *vqs = kmalloc(2 * sizeof(*vqs), GFP_KERNEL);
    
    // Create two virtqueues: TX and RX
    vhost_net_init_vq(n, vqs, VHOST_NET_VQ_TX);
    vhost_net_init_vq(n, vqs + 1, VHOST_NET_VQ_RX);
    
