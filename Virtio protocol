    vhost_poll_init(&n->poll[VHOST_NET_VQ_TX], 
                    handle_tx_net, POLLOUT, dev);
    vhost_poll_init(&n->poll[VHOST_NET_VQ_RX], 
                    handle_rx_net, POLLIN, dev);
    
    return 0;
}

// Data path: completely in kernel
static void handle_rx_net(struct vhost_net *net)
{
    struct vhost_virtqueue *vq = &net->vqs[VHOST_NET_VQ_RX];
    
    // 1. Pop descriptors from virtqueue
    struct vhost_net_virtqueue *nvq = container_of(vq, ...);
    struct vhost_skb *skb = get_skb_from_ring(nvq);
    
    // 2. Process packet (zero-copy if possible)
    if (vhost_net_tx_sg(vq, skb) == 0) {
        // 3. Push to used ring
        vhost_add_used(vq, head, len);
    }
    
    // 4. Notify guest
    vhost_signal(vq);
}
