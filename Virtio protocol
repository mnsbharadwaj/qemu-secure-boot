Section 5.1: NVIDIA GPUDirect + Virtio

Problem: GPU Memory Access

Traditional Path:

```
GPU Memory → CPU (via PCIe) → Guest RAM → QEMU → Host → ... 
           (10GB/s)         (20GB/s)        (software copy)
```

Latency: ~10μs extra overhead

GPUDirect + Virtio:

```
GPU Memory ←→ Guest Driver (virtio) ←→ Host ←→ ...
           (direct DMA)
```

Latency: ~2μs overhead

Implementation

```c
// NVIDIA GPUDirect virtio device
typedef struct VirtIOGPU {
    VirtIODevice parent;
    VirtQueue *ctrl_vq;   // Control queue (commands)
    VirtQueue *data_vq;   // Data queue (GPU memory transfers)
    
    // GPU memory information
    void *gpu_va;         // GPU virtual address
    size_t gpu_size;      // Size of GPU memory region
    struct iommu_domain *iommu;  // IOMMU for DMA
} VirtIOGPU;

// Command: Map GPU memory to guest
static void gpu_handle_ctrl(VirtIODevice *vdev, VirtQueue *vq)
{
    VirtIOGPU *gpu = VIRTIO_GPU(vdev);
    VirtQueueElement *elem;
    
    elem = virtqueue_pop(vq, sizeof(VirtQueueElement));
    
    // 1. Read command
    struct gpu_cmd *cmd = map_descriptor(elem);
    
    // 2. Allocate DMA mapping for guest
    dma_addr_t guest_addr = iommu_map(gpu->iommu,
                                       cmd->guest_gpa,
                                       cmd->size,
                                       DMA_READ | DMA_WRITE);
    
    // 3. Map GPU memory to this address
    iommu_map(gpu->iommu,
              guest_addr,
              gpu->gpu_va + cmd->offset,
              cmd->size,
              DMA_READ | DMA_WRITE);
    
    // 4. Return mapping info to guest
    // Now guest can access GPU memory directly!
    
    virtqueue_push(vq, elem, sizeof(*cmd));
    virtio_notify(vdev, vq);
}
```

