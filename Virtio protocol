// SEV-enabled virtio device
static void sev_virtio_handle_output(VirtIODevice *vdev, VirtQueue *vq)
{
    // 1. QEMU cannot read guest memory
    // 2. It must use the guest's ephemeral key
    
    // Use SEV's shared buffer mechanism
