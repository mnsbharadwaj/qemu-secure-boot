Section 3.2: qcow2 Format Deep Dive

qcow2 File Structure

```
┌─────────────────────────────────────────────────────────────────┐
│                    QCOW2 FILE STRUCTURE                         │
│                                                                 │
│  Header (64 bytes)                                             │
│  ┌─────────────────────────────────────────────────────────┐   │
│  │  magic: 'QFI\xfb'                                     │   │
│  │  version: 2 or 3                                      │   │
│  │  cluster_bits: 12 (4KB) or 16 (64KB)                 │   │
│  │  size: total disk size (in bytes)                    │   │
│  │  l1_table_offset: offset of L1 table                 │   │
│  │  l1_size: number of L1 entries                        │   │
│  │  refcount_table_offset: offset of refcount table     │   │
│  │  snapshot_table_offset: offset of snapshot table     │   │
│  └─────────────────────────────────────────────────────────┘   │
│                                                                 │
│  L1 Table (array of L2 table addresses)                       │
│  ┌─────────────────────────────────────────────────────────┐   │
│  │  [l2_table_0] [l2_table_1] [l2_table_2] ...           │   │
│  └─────────────────────────────────────────────────────────┘   │
│                              ↓                                  │
│  L2 Table (cluster descriptors)                                │
│  ┌─────────────────────────────────────────────────────────┐   │
│  │  [cluster_0] [cluster_1] [cluster_2] ...              │   │
│  └─────────────────────────────────────────────────────────┘   │
│                              ↓                                  │
│  Data Clusters (actual guest data)                             │
│  ┌─────────────────────────────────────────────────────────┐   │
│  │  [block 0] [block 1] [block 2] ...                    │   │
│  └─────────────────────────────────────────────────────────┘   │
│                                                                 │
│  Refcount Table (cluster allocation)                           │
│  ┌─────────────────────────────────────────────────────────┐   │
│  │  [refcount 0] [refcount 1] [refcount 2] ...           │   │
│  └─────────────────────────────────────────────────────────┘   │
│                                                                 │
│  Snapshot Table                                                 │
│  ┌─────────────────────────────────────────────────────────┐   │
│  │  [snapshot 0] [snapshot 1] [snapshot 2] ...           │   │
│  └─────────────────────────────────────────────────────────┘   │
└─────────────────────────────────────────────────────────────────┘
```

qcow2 Header Analysis

```python
#!/usr/bin/env python3
"""
qcow2 Header Parser
"""

import struct
import sys

class Qcow2Header:
    def __init__(self, data):
        self.magic = data[0:4]
        self.version = struct.unpack('>I', data[4:8])[0]
        self.backing_file_offset = struct.unpack('>Q', data[8:16])[0]
        self.backing_file_size = struct.unpack('>I', data[16:20])[0]
        self.cluster_bits = struct.unpack('>I', data[20:24])[0]
        self.size = struct.unpack('>Q', data[24:32])[0]
        self.crypt_method = struct.unpack('>I', data[32:36])[0]
        self.l1_size = struct.unpack('>I', data[36:40])[0]
        self.l1_table_offset = struct.unpack('>Q', data[40:48])[0]
        self.refcount_table_offset = struct.unpack('>Q', data[48:56])[0]
        self.refcount_table_clusters = struct.unpack('>I', data[56:60])[0]
        self.nb_snapshots = struct.unpack('>I', data[60:64])[0]
        self.snapshots_offset = struct.unpack('>Q', data[64:72])[0]
        
    def display(self):
        print(f"Magic: {self.magic}")
        print(f"Version: {self.version}")
        print(f"Cluster bits: {self.cluster_bits} ({1 << self.cluster_bits} bytes)")
        print(f"Disk size: {self.size / (1024**3):.2f} GB")
        print(f"L1 table size: {self.l1_size} entries")
        print(f"L1 table offset: 0x{self.l1_table_offset:x}")
        print(f"Refcount table offset: 0x{self.refcount_table_offset:x}")
        print(f"Number of snapshots: {self.nb_snapshots}")

def parse_qcow2(filename):
    with open(filename, 'rb') as f:
        header = f.read(72)  # Minimum header size
    return Qcow2Header(header)

if __name__ == '__main__':
    if len(sys.argv) < 2:
        print(f"Usage: {sys.argv[0]} <qcow2-file>")
        sys.exit(1)
    
    header = parse_qcow2(sys.argv[1])
    header.display()
```

qcow2 Cluster Allocation

```c
// block/qcow2-cluster.c - simplified

int qcow2_alloc_clusters(BlockDriverState *bs, uint64_t size) {
    BDRVQcow2State *s = bs->opaque;
    int nb_clusters = size >> s->cluster_bits;
    
    // 1. Find free clusters in refcount table
    int first_free = qcow2_find_free_cluster(bs, 0, nb_clusters);
    if (first_free < 0) {
        return -ENOSPC;
    }
    
    // 2. Mark clusters as used
    for (int i = 0; i < nb_clusters; i++) {
        qcow2_update_refcount(bs, first_free + i, 1, 1);
    }
    
    return first_free;
}

// Read from guest offset
int qcow2_read(BlockDriverState *bs, uint64_t offset,
                uint8_t *buf, size_t len) {
    BDRVQcow2State *s = bs->opaque;
    
    // 1. Find cluster index
    uint64_t cluster = offset >> s->cluster_bits;
    
    // 2. L1 table lookup
    uint64_t l1_index = cluster >> (s->cluster_bits - 3);
    uint64_t l2_offset = s->l1_table[l1_index];
    
    // 3. L2 table lookup
    uint64_t l2_index = cluster & (s->l2_size - 1);
    uint64_t cluster_offset = s->l2_table[l2_index];
    
    // 4. Read cluster
    pread(s->file_fd, buf, len, cluster_offset);
    
    return len;
}
```

