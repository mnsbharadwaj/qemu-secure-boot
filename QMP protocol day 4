// hw/virtio/virtio.c

VirtioStats *qmp_query_virtio_stats(const char *device_id, Error **errp)
{
    VirtIODevice *vdev = find_virtio_device(device_id);
    if (!vdev) {
        error_setg(errp, "Device '%s' not found", device_id);
        return NULL;
    }
    
