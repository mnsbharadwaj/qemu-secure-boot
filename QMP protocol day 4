Section 2.3: Python QMP Client

Complete Client Implementation

```python
#!/usr/bin/env python3
"""
QMP Python Client - From Scratch
"""

import json
import socket
import struct
import time

class QMPClient:
    def __init__(self, sock_path='/tmp/qmp.sock'):
        self.sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self.sock.connect(sock_path)
        self.next_id = 0
        self._receive_greeting()
        self._negotiate()
    
    def _receive_greeting(self):
        """Receive QMP greeting"""
        data = self._read_json()
        assert 'QMP' in data, "Not QMP greeting"
        print(f"Connected to QEMU version {data['QMP']['version']['qemu']}")
    
    def _negotiate(self):
        """Enable QMP capabilities"""
        resp = self.execute('qmp_capabilities')
        assert resp == {}, f"Negotiation failed: {resp}"
    
    def _read_json(self):
        """Read a JSON message (zero-copy)"""
        # 1. Read length prefix
        header = self.sock.recv(4)
        length = struct.unpack('!I', header)[0]
        
        # 2. Read JSON data
        data = b''
        while len(data) < length:
            chunk = self.sock.recv(length - len(data))
            data += chunk
        
        return json.loads(data.decode('utf-8'))
    
    def execute(self, command, args=None):
        """Execute a QMP command"""
        self.next_id += 1
        
        # 1. Build request
        request = {'execute': command, 'id': str(self.next_id)}
        if args:
            request['arguments'] = args
        
        # 2. Send request
        json_str = json.dumps(request)
        self.sock.send(struct.pack('!I', len(json_str)))
        self.sock.send(json_str.encode('utf-8'))
        
        # 3. Receive response
        while True:
            response = self._read_json()
            if 'id' in response and response['id'] == str(self.next_id):
                break
        
        # 4. Check for error
        if 'error' in response:
            raise Exception(f"QMP error: {response['error']['desc']}")
        
        return response.get('return', {})
    
    def close(self):
        self.sock.close()

# Usage
if __name__ == '__main__':
    # 1. Connect
    client = QMPClient('/tmp/qmp.sock')
    
    # 2. Query version
    version = client.execute('query-version')
    print(f"QEMU version: {version['qemu']['major']}.{version['qemu']['minor']}.{version['qemu']['micro']}")
    
    # 3. Query status
    status = client.execute('query-status')
    print(f"VM status: {status['status']}")
    
    # 4. Query memory devices
    memory = client.execute('query-memory-devices')
    print(f"Memory devices: {memory}")
    
    # 5. Close
    client.close()
```

