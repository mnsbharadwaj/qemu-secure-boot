struct HierarchicalAddressSpace {
    AddressSpace *parent;          // Global system_memory
    AddressSpace *child;           // Per-VM
    uint64_t offset;               // Offset in parent
    MemoryRegion *root;            // Child's MemoryRegion tree
};
```

