Section 2.2: MemoryRegionOps

MMIO Callbacks

```c
struct MemoryRegionOps {
    // Read and write handlers
    uint64_t (*read)(void *opaque, hwaddr addr, unsigned size);
    void (*write)(void *opaque, hwaddr addr, uint64_t data, unsigned size);
    
    // Valid ranges (where read/write are legal)
    struct {
        hwaddr min_access_size;
        hwaddr max_access_size;
        unsigned align;           // Alignment required
    } valid;
    
    // Implementation details (granularity)
    struct {
        hwaddr min_access_size;
        hwaddr max_access_size;
        unsigned align;
        bool unaligned;           // Allow unaligned access?
    } impl;
    
    enum Endianness endianness;   // DEVICE_LITTLE_ENDIAN, DEVICE_BIG_ENDIAN
};
```

Example: Custom MMIO Device

```c
// Custom device with 32-bit registers
typedef struct MyDevice {
    uint32_t regs[16];
} MyDevice;

static uint64_t my_read(void *opaque, hwaddr addr, unsigned size) {
    MyDevice *dev = opaque;
    return dev->regs[addr >> 2];
}

static void my_write(void *opaque, hwaddr addr, uint64_t data, unsigned size) {
    MyDevice *dev = opaque;
    dev->regs[addr >> 2] = data;
}

static const MemoryRegionOps my_ops = {
    .read = my_read,
    .write = my_write,
    .endianness = DEVICE_LITTLE_ENDIAN,
    .valid = {
        .min_access_size = 4,
        .max_access_size = 4,
        .align = 4,
    },
    .impl = {
        .min_access_size = 4,
        .max_access_size = 4,
        .align = 4,
    },
};

// Usage
MemoryRegion *mmio = g_new(MemoryRegion, 1);
memory_region_init_io(mmio, NULL, &my_ops, dev, "my-mmio", 0x1000);
```

Performance Impact:

· RAM access: ~1ns (direct memory read)
· MMIO access: ~100ns (function call overhead)
· Reason: MMIO calls through function pointers

