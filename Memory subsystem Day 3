FlatView Caching

```c
// system/physmem.c

// FlatView is cached to avoid recomputation on every access
struct AddressSpaceDispatch {
    struct MemoryRegionSection *mru_section;  // Most recently used
    int sections;                             // Number of sections
    struct MemoryRegionSection **sections;    // Array of sections
};

// Fast path: check cached region
