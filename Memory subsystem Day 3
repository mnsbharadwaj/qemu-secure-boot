    // SMMU-specific state
};
```

IOMMU Translation

```c
static IOMMUTLBEntry smmu_translate(IOMMUMemoryRegion *iommu,
                                     hwaddr addr, IOMMUAccessFlags flag) {
    SMMUState *s = container_of(iommu, SMMUState, iommu);
    IOMMUTLBEntry entry = {};
    
    // 1. Find stream ID
    // 2. Find context (SMMU context bank)
    // 3. Translate address
    // 4. Return IOMMU translation
    entry.iova = addr;
    entry.translated_addr = translated_addr;
    entry.addr_mask = ~(page_size - 1);
    entry.perm = IOMMU_RW;
    
    return entry;
}
```

Guest-Controlled IOMMU

```c
// VIRTIO_F_IOMMU_PLATFORM
// Guest can use DMA API to map guest memory

void virtio_iommu_map(VirtIODevice *vdev, hwaddr iova, hwaddr pa,
                       size_t len, int flags) {
    // 1. Guest calls VIRTIO_IOMMU_T_MAP
    // 2. QEMU maps guest physical address → IOMMU
    // 3. Device can access guest memory via IOVA
    
    IOMMUTLBEntry entry = {
        .iova = iova,
        .translated_addr = pa,
        .addr_mask = ~(len - 1),
        .perm = flags,
    };
    iommu_notify(vdev->iommu, &entry);
}
```

