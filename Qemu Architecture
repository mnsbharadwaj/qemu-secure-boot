    char *name;
    MemoryRegion *root;
    struct AddressSpaceDispatch *dispatch;
    struct MemoryRegion *current_map;
};

// Memory region operations
struct MemoryRegionOps {
    uint64_t (*read)(void *opaque, hwaddr addr, unsigned size);
    void (*write)(void *opaque, hwaddr addr, uint64_t data, unsigned size);
    enum Endianness endianness;
    bool valid;
};
```

Address Translation Pipeline

```c
// GPA → HVA translation
void *address_space_map(AddressSpace *as,
                        hwaddr addr,    // Guest Physical Address
                        hwaddr *len,
                        bool is_write) {
    // 1. Find MemoryRegion
    MemoryRegion *mr = address_space_find_mr(as, addr);
    
    // 2. Check if RAM
    if (memory_region_is_ram(mr)) {
        // Direct mapping
        void *ram_ptr = memory_region_get_ram_ptr(mr);
        return ram_ptr + (addr - mr->addr);
    }
    
    // 3. MMIO or bounce buffer
    if (memory_region_is_mmio(mr)) {
        // Need bounce buffer for MMIO
        void *bounce = g_malloc(*len);
        if (is_write) {
            // Write to bounce buffer, then device will read
        }
        return bounce;
    }
    
    // 4. Invalid region
    return NULL;
}

// Memory region lookup (optimized)
MemoryRegion *address_space_find_mr(AddressSpace *as, hwaddr addr) {
    // 1. Check dispatch cache
    if (as->current_map && addr >= as->current_map->addr &&
        addr < as->current_map->addr + as->current_map->size) {
        return as->current_map->mr;
    }
    
    // 2. Full lookup
    return address_space_lookup(as->dispatch, addr);
}
