Section 1.3: QEMU Object Model (QOM)

The Foundation: Object-Oriented C

```c
// include/qom/object.h

// Base object type
struct ObjectClass {
    TypeInfo *type_info;
    ObjectClass *parent;
    void (*properties)(Object *obj, Visitor *v, void *opaque);
    void (*finalize)(Object *obj);
};

// Base object
struct Object {
    ObjectClass *class;
    Object *parent;
    uint32_t ref;
    char *id;
    GHashTable *properties;
};

// Type information (like a class definition)
struct TypeInfo {
    const char *name;
    const char *parent;
    size_t instance_size;
    void (*instance_init)(Object *obj);
    void (*instance_finalize)(Object *obj);
    void (*class_init)(ObjectClass *klass, void *data);
    void (*class_finalize)(ObjectClass *klass, void *data);
    void *class_data;
};

// Device class (extends Object)
struct DeviceClass {
    ObjectClass parent_class;
    void (*realize)(DeviceState *dev, Error **errp);
    void (*unrealize)(DeviceState *dev, Error **errp);
    void (*reset)(DeviceState *dev);
    Property *props;
};

// PCI Device (extends Device)
struct PCIDeviceClass {
    DeviceClass parent_class;
    void (*realize)(PCIDevice *dev, Error **errp);
    uint16_t device_id;
    uint16_t vendor_id;
    uint16_t class_id;
    uint16_t subsystem_vendor_id;
    uint16_t subsystem_id;
    uint32_t revision;
};

// Virtio Device (extends PCI Device)
struct VirtioPCIDeviceClass {
    PCIDeviceClass parent_class;
    void (*realize)(VirtIOPCIProxy *dev, Error **errp);
};

// Example: virtio-blk device type
static const TypeInfo virtio_blk_info = {
    .name = TYPE_VIRTIO_BLK,
    .parent = TYPE_VIRTIO_DEVICE,
    .instance_size = sizeof(VirtIOBlock),
    .class_init = virtio_blk_class_init,
    .instance_init = virtio_blk_instance_init,
};
```

QOM Hierarchy for Virtio-Blk

```
Object
  └── Device (hw/core/qdev.c)
        └── VirtIODevice (hw/virtio/virtio.c)
              └── VirtIOBlock (hw/block/virtio-blk.c)
                    ├── VirtIOBlockPCI (hw/virtio/virtio-blk-pci.c)
