3. CPU notification:

```c
// In KVM mode: inject interrupt via KVM
static void kvm_inject_irq(CPUState *cpu, int vector) {
    struct kvm_vcpu_events events = {0};
    events.exception.injected = 1;
    events.exception.nr = vector;
    kvm_vcpu_ioctl(cpu, KVM_SET_VCPU_EVENTS, &events);
}

// In TCG mode: signal pending interrupt
static void tcg_cpu_interrupt(CPUState *cpu, int mask) {
    cpu->interrupt_request |= mask;
    cpu_interrupt(cpu);
}
