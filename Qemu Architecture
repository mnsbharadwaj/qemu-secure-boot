static void fpga_handle_data(VirtIODevice *vdev, VirtQueue *vq) {
    VirtIOFPGA *fpga = VIRTIO_FPGA(vdev);
    VirtQueueElement *elem;
    
    elem = virtqueue_pop(vq, sizeof(VirtQueueElement));
    
    // VFIO handles data directly (zero-copy)
    vfio_fpga_transfer(fpga->vfio_dev, elem->out_sg, elem->in_sg);
    
    virtqueue_push(vq, elem, 0);
    virtio_notify(vdev, vq);
}
