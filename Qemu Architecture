// Control queue: load bitstream, set parameters
static void fpga_handle_ctrl(VirtIODevice *vdev, VirtQueue *vq) {
    VirtIOFPGA *fpga = VIRTIO_FPGA(vdev);
    VirtQueueElement *elem;
    
    elem = virtqueue_pop(vq, sizeof(VirtQueueElement));
    struct fpga_ctrl_cmd *cmd = map_descriptor(elem);
    
    switch (cmd->op) {
    case FPGA_LOAD_BITSTREAM:
        // Load bitstream via VFIO
        vfio_load_bitstream(fpga->vfio_dev, cmd->data, cmd->len);
        fpga->bitstream_loaded = true;
        break;
    case FPGA_START:
        vfio_fpga_start(fpga->vfio_dev);
        break;
    }
    
    virtqueue_push(vq, elem, sizeof(*cmd));
    virtio_notify(vdev, vq);
}

