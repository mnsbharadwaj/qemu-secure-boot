  ↓ (mmap)
NVDIMM (pmem)
```

Implementation:

1. Virtio-PMEM device:

```c
typedef struct VirtIOPMEM {
    VirtIODevice parent;
    VirtQueue *vq;
    MemoryRegion pmem;
    int fd;
    void *pmem_ptr;
    uint64_t pmem_size;
    bool dax_supported;
} VirtIOPMEM;

// DAX mode: guest mmaps PMEM directly
static void pmem_dax_mmap(VirtIOPMEM *pmem) {
    // 1. Map PMEM to host
    pmem->pmem_ptr = mmap(NULL, pmem->pmem_size,
                          PROT_READ | PROT_WRITE,
                          MAP_SHARED, pmem->fd, 0);
    
    // 2. Register with guest via virtio
    // Guest can now mmap this memory
    guest_mmap(pmem->pmem_ptr, pmem->pmem_size);
}

// Block mode: traditional I/O
static void pmem_handle_io(VirtIODevice *vdev, VirtQueue *vq) {
    VirtIOPMEM *pmem = VIRTIO_PMEM(vdev);
    VirtQueueElement *elem;
    
    elem = virtqueue_pop(vq, sizeof(VirtQueueElement));
    
    if (elem->out_sg) {
        // Write to PMEM
        iov_to_buf(elem->out_sg, elem->out_num, 0,
                   pmem->pmem_ptr + elem->offset, elem->len);
        // Ensure persistence
        pmem_flush(pmem->pmem_ptr + elem->offset, elem->len);
    } else {
        // Read from PMEM
        iov_from_buf(elem->in_sg, elem->in_num, 0,
                     pmem->pmem_ptr + elem->offset, elem->len);
    }
    
    virtqueue_push(vq, elem, elem->len);
    virtio_notify(vdev, vq);
}
```

2. Persistent memory operations:

```c
// Flush to persistence (clflush, sfence)
void pmem_flush(void *addr, size_t len) {
#ifdef __x86_64__
    for (void *p = addr; p < addr + len; p += 64) {
        asm volatile("clflush %0" : : "m"(*(char *)p));
    }
    asm volatile("sfence" : : : "memory");
#else
    // ARM: dc cvac, dsb ish
    for (void *p = addr; p < addr + len; p += 64) {
        asm volatile("dc cvac, %0" : : "r"(p) : "memory");
    }
    asm volatile("dsb ish" : : : "memory");
#endif
}
```

Performance: 10GB/s in DAX mode, near-native.

