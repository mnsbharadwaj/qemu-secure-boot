Section 2.1: The QEMU Main Loop

Complete Main Loop Flow

```c
// softmmu/vl.c (simplified)
int main(int argc, char **argv) {
    // 1. Parse command line
    qemu_init(argc, argv);
    
    // 2. Create machine
    machine = machine_init();
    
    // 3. Initialize CPUs
    cpu_init(machine);
    
    // 4. Initialize devices
    device_init(machine);
    
    // 5. Initialize memory
    memory_init(machine);
    
    // 6. Start main loop
    if (kvm_enabled()) {
        // KVM mode: run in vCPU threads
        qemu_kvm_init();
    } else {
        // TCG mode: run in main thread
        qemu_tcg_init();
    }
    
    // 7. Main event loop
    main_loop();
    
    return 0;
}

// The main loop
static void main_loop(void) {
    while (!qemu_shutdown_request()) {
        // 1. Check for I/O events
        int ret = qemu_poll_ns(events, timeout);
        
        // 2. Process I/O events
        while (events_available()) {
            process_event(event);
        }
        
        // 3. Run CPU (if time)
        if (cpu_can_run()) {
            qemu_cpu_kick(cpu);
            qemu_cpu_exec(cpu);
        }
        
        // 4. Check migration
        if (migration_pending()) {
            migration_check();
        }
        
        // 5. Process monitor commands
        monitor_handle_command();
        
        // 6. Update timer
        update_timers();
    }
}
```

Event Loop Detailed

```c
// QEMU uses the glib main loop
typedef struct QEMUEvent {
    int fd;                // File descriptor
    int events;            // POLLIN, POLLOUT, etc.
    void (*callback)(void *opaque);
    void *opaque;
} QEMUEvent;

// Register an event
void qemu_add_fd_event(int fd, 
                       void (*callback)(void *),
                       void *opaque) {
    QEMUEvent *event = g_new(QEMUEvent, 1);
    event->fd = fd;
    event->callback = callback;
    event->opaque = opaque;
    
