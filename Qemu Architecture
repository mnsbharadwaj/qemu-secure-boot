Section 4.2: QEMU with VFIO (Passthrough)

VFIO Architecture

```c
// hw/vfio/pci.c

typedef struct VFIOPCIDevice {
    PCIDevice pdev;
    int fd;                 // VFIO container fd
    int group_fd;           // VFIO group fd
    void *vaddr;            // mmap'd BARs
    size_t vaddr_size;
    uint32_t features;
    bool has_flr;           // Function-Level Reset
} VFIOPCIDevice;

// Initialize VFIO device
static void vfio_realize(PCIDevice *dev, Error **errp) {
    VFIOPCIDevice *vdev = VFIO_PCI(dev);
    
    // 1. Open VFIO container
    vdev->fd = open("/dev/vfio/vfio", O_RDWR);
    
    // 2. Set up IOMMU
    ioctl(vdev->fd, VFIO_SET_IOMMU, VFIO_TYPE1_IOMMU);
    
    // 3. Add device to group
    vdev->group_fd = open("/dev/vfio/group", O_RDWR);
    ioctl(vdev->group_fd, VFIO_GROUP_SET_CONTAINER, &vdev->fd);
    
    // 4. Get device info
    struct vfio_device_info dev_info;
    ioctl(dev_fd, VFIO_DEVICE_GET_INFO, &dev_info);
    
    // 5. mmap device BARs
    for (int i = 0; i < dev_info.num_regions; i++) {
        struct vfio_region_info reg_info;
        ioctl(dev_fd, VFIO_DEVICE_GET_REGION_INFO, &reg_info);
        vdev->vaddr = mmap(NULL, reg_info.size, PROT_READ | PROT_WRITE,
                           MAP_SHARED, dev_fd, reg_info.offset);
    }
}
```

