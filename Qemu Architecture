Section 3.2: Live Migration Deep Dive

Migration State Machine

```
┌─────────────────────────────────────────────────────────────────┐
│                    MIGRATION STATE MACHINE                      │
│                                                                 │
│  START → SETUP → ITERATIVE → COMPLETE → FINISH                 │
│    ↑        ↓           ↓          ↓         ↓                 │
│    └────────┴───────────┴──────────┴─────────┘                 │
│                                                                 │
│  States:                                                        │
│  - SETUP: Prepare migration                                     │
│  - ITERATIVE: Copy memory pages                                 │
│  - COMPLETE: Final synchronization                              │
│  - FINISH: Stop source VM, start destination                   │
└─────────────────────────────────────────────────────────────────┘
```

Migration Code Flow

```c
// migration/migration.c

// Start migration
void qmp_migrate(const char *uri, Error **errp) {
    MigrationState *s = migrate_get_current();
    
    // 1. Setup
    s->state = MIGRATION_STATE_SETUP;
    s->uri = g_strdup(uri);
    
    // 2. Start migration thread
    qemu_thread_create(&s->thread, "migration", 
                       migration_thread, s, QEMU_THREAD_JOINABLE);
}

// Migration thread
static void *migration_thread(void *opaque) {
    MigrationState *s = opaque;
    
    while (s->state != MIGRATION_STATE_COMPLETED) {
        // 3. Iterative phase
        int64_t start_time = qemu_clock_get_ms(QEMU_CLOCK_REALTIME);
        
        // Copy memory pages
        migration_bitmap_sync(s);
        int pages = ram_save_iterate(s->to_dst_file, s);
        
        // Check completion
        if (ram_bytes_remaining() == 0) {
            // 4. Final sync
            s->state = MIGRATION_STATE_COMPLETED;
            ram_save_complete(s->to_dst_file);
            break;
        }
        
        // 5. Check timeout/throttling
        uint64_t time = qemu_clock_get_ms(QEMU_CLOCK_REALTIME) - start_time;
        if (time < s->downtime_limit) {
            g_usleep(s->downtime_limit - time);
        }
    }
    
    // 6. Finish
    s->state = MIGRATION_STATE_FINISHED;
    qemu_savevm_send_ping(s->to_dst_file, 0);
    return NULL;
}
```

