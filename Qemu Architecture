Block Request Flow

```c
// 1. virtio-blk receives request
static void virtio_blk_handle_request(VirtIOBlock *s, 
                                       VirtQueueElement *elem) {
    // 2. Parse descriptor
    struct virtio_blk_req *req = map_descriptor(elem);
    
    // 3. Create block request
    BlockBackend *blk = s->blk;
    QEMUIOVector qiov;
    qemu_iovec_init(&qiov, elem->in_num + elem->out_num);
    qemu_iovec_add(&qiov, elem->out_sg, elem->out_num);
    
    // 4. Submit to block layer
    if (req->type == VIRTIO_BLK_T_OUT) {
        // Write
        blk_aio_pwritev(blk, req->sector * 512, &qiov, 0,
                        virtio_blk_complete, elem);
    } else {
        // Read
        blk_aio_preadv(blk, req->sector * 512, &qiov, 0,
                       virtio_blk_complete, elem);
    }
}

// 5. Block backend handles I/O
BlockAIOCB *blk_aio_preadv(BlockBackend *blk, int64_t offset,
                           QEMUIOVector *qiov, int flags,
                           BlockCompletionFunc *cb, void *opaque) {
    // 6. Pass to block driver
    return bdrv_aio_preadv(blk->root, offset, qiov, flags, cb, opaque);
}

// 7. Block driver (qcow2, raw, etc.) handles I/O
BlockAIOCB *bdrv_aio_preadv(BlockDriverState *bs, int64_t offset,
                             QEMUIOVector *qiov, int flags,
                             BlockCompletionFunc *cb, void *opaque) {
    // 8. I/O engine
    if (bs->file && bs->file->drv->bdrv_aio_preadv) {
        return bs->file->drv->bdrv_aio_preadv(bs->file, offset,
                                               qiov, flags, cb, opaque);
    }
    // Fallback to generic
    return bdrv_co_preadv(bs, offset, qiov, flags);
}

// 9. I/O engine (io_uring, AIO, etc.)
static int io_uring_do_read(BlockDriverState *bs, QEMUIOVector *qiov,
                             int64_t offset, BlockCompletionFunc *cb) {
    // 10. Submit to kernel
    struct io_uring_sqe *sqe = io_uring_get_sqe(&ring);
    io_uring_prep_readv(sqe, fd, qiov->iov, qiov->niov, offset);
    io_uring_sqe_set_data(sqe, cb);
    io_uring_submit(&ring);
    
    return 0; // Async
}
