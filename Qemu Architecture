// Allocate memory on specific node
void *allocate_on_node(size_t size, int node) {
    void *ptr = mmap(NULL, size, PROT_READ | PROT_WRITE,
                     MAP_PRIVATE | MAP_ANONYMOUS | MAP_HUGETLB,
                     -1, 0);
    // Set memory policy
    mbind(ptr, size, MPOL_BIND, &node, 1, 0);
    return ptr;
}
```

3. CPU Affinity:

```c
// Pin vCPUs to physical CPUs
void set_cpu_affinity(CPUState *cpu, int node) {
    cpu_set_t cpuset;
    CPU_ZERO(&cpuset);
    for (int i = 0; i < smp_cores; i++) {
        if (cpu->numa_node == node) {
            CPU_SET(i, &cpuset);
        }
    }
    sched_setaffinity(0, sizeof(cpuset), &cpuset);
}
```

